{
  "name": "apocalypse-bench",
  "version": "1.0.0",
  "description": "apocbench: offline survival/apocalypse LLM benchmark runner",
  "private": true,
  "type": "module",
  "bin": {
    "apocbench": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsup",
    "bench:free-models": "echo 'Inline judge benchmarks are disabled. Run candidate-only benchmarks and score with pnpm -s rejudge:codex.' && exit 1",
    "bench:lfm2.5": "echo 'Inline judge benchmarks are disabled. Run candidate-only benchmarks and score with pnpm -s rejudge:codex.' && exit 1",
    "bench:model-pack": "echo 'Inline judge benchmarks are disabled. Run candidate-only benchmarks and score with pnpm -s rejudge:codex.' && exit 1",
    "wiki:rust:test": "cargo test -p wiki-search",
    "wiki:embed:test": "python3 -m unittest scripts/wiki_embed_test.py",
    "wiki:ingest:fixture": "cargo run -p wiki-search -- ingest --input crates/wiki-search/tests/fixtures/wiki-mini.jsonl --out data/wiki/fixture",
    "wiki:serve:fixture": "cargo run -p wiki-search -- serve --index data/wiki/fixture",
    "rejudge:codex": "PATH=/Users/tristan/.local/share/fnm/node-versions/v24.11.1/installation/bin:$PATH tsx scripts/codex_rejudge.ts",
    "retrieval-debug:config": "PATH=/Users/tristan/.local/share/fnm/node-versions/v24.11.1/installation/bin:$PATH tsx scripts/make_retrieval_debug_config.ts",
    "retrieval-debug:report": "PATH=/Users/tristan/.local/share/fnm/node-versions/v24.11.1/installation/bin:$PATH tsx scripts/retrieval_debug_report.ts",
    "dataset:export": "tsx src/cli/exportDataset.ts",
    "dev": "tsx src/cli/index.tsx",
    "lint": "eslint src test",
    "format": "prettier -w .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "scripts/check-no-next-artifacts.sh && vitest",
    "verify:install": "pnpm install --frozen-lockfile"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.23.0",
  "dependencies": {
    "@ai-sdk/openai-compatible": "^1.0.39",
    "@ai-sdk/provider-utils": "^3.0.19",
    "@earendil-works/pi-agent-core": "0.75.4",
    "@earendil-works/pi-ai": "0.75.4",
    "@openrouter/ai-sdk-provider": "^1.5.4",
    "@stricli/core": "^1.2.4",
    "ai": "^5.0.116",
    "better-sqlite3": "^12.5.0",
    "dotenv": "^17.2.3",
    "ink": "^6.5.1",
    "ollama-ai-provider-v2": "^1.5.5",
    "p-queue": "^9.0.1",
    "pino": "^10.1.0",
    "react": "^19.2.3",
    "yaml": "^2.8.2",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@ai-sdk/provider": "^2.0.0",
    "@eslint/js": "^9.39.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "prettier": "^3.7.4",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.0",
    "vitest": "^4.0.16"
  },
  "pnpm": {
    "overrides": {
      "@earendil-works/pi-ai": "0.75.4"
    }
  }
}
